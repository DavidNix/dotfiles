#!/usr/bin/env bash
# Run OpenCode in an isolated Apple Container environment.

set -euo pipefail

SANDBOX_LAYOUT_VERSION="home-v2"
SANDBOX_IMAGE="ai-sandbox:${SANDBOX_LAYOUT_VERSION}"
SANDBOX_HOME="/home/sandbox"
SANDBOX_PATH="${SANDBOX_HOME}/.opencode/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
DOCKERFILE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { printf '%b[INFO]%b %s\n' "$BLUE" "$NC" "$*"; }
log_success() { printf '%b[OK]%b %s\n' "$GREEN" "$NC" "$*"; }
log_warn() { printf '%b[WARN]%b %s\n' "$YELLOW" "$NC" "$*"; }
log_error() { printf '%b[ERROR]%b %s\n' "$RED" "$NC" "$*" >&2; }

usage() {
    cat <<EOF
Usage: ai-sandbox [build|reset|prune|shell] [--] [OPENCODE_ARGS...]

Run OpenCode without external plugins in a persistent Apple Container sandbox
for the current directory.

COMMANDS:
    build       Build/rebuild the sandbox image
    reset       Remove the sandbox for the current directory
    prune       Delete all ai-sandbox containers
    shell       Open an interactive shell inside the sandbox

With no command, ai-sandbox starts OpenCode in the current directory.

OPTIONS:
    -h, --help  Show this help message

EXAMPLES:
    ai-sandbox                  # Run opencode in the sandbox
    ai-sandbox --help           # Show this help message
    ai-sandbox -- --help        # Pass --help to opencode
    ai-sandbox build --no-cache # Rebuild from scratch
    ai-sandbox reset            # Remove the current sandbox

EOF
}

ensure_system_running() {
    if ! container ls >/dev/null 2>&1; then
        log_info "Starting container system..."
        if [[ -t 0 ]]; then
            container system start
        else
            printf 'Y\n' | container system start
        fi
        sleep 2
    fi
}

build_image() {
    local force="${1:-}"
    local no_cache="${2:-}"

    if [[ -z "$force" ]] && image_exists "$SANDBOX_IMAGE"; then
        return 0
    fi

    local host_uid host_gid
    host_uid=$(id -u)
    host_gid=$(id -g)

    log_info "Building sandbox image..."

    local build_args=(
        -f "${DOCKERFILE_DIR}/Dockerfile.ai-sandbox"
        -t "$SANDBOX_IMAGE"
        --build-arg "SANDBOX_UID=${host_uid}"
        --build-arg "SANDBOX_GID=${host_gid}"
    )
    if [[ -n "$no_cache" ]]; then
        build_args+=(--no-cache)
    fi
    build_args+=("${DOCKERFILE_DIR}")

    run_container_build "${build_args[@]}"
    log_success "Image built successfully"
}

image_exists() {
    local image="$1"
    local name tag

    name="${image%%:*}"
    tag="${image#*:}"
    [[ "$tag" != "$image" ]] || tag="latest"

    container image list 2>/dev/null | awk -v name="$name" -v tag="$tag" '
        NR > 1 && $1 == name && $2 == tag { found = 1 }
        END { exit found ? 0 : 1 }
    '
}

run_container_build() {
    local log_file status

    log_file=$(mktemp)
    set +e
    container build "$@" > >(tee "$log_file") 2>&1
    status=$?
    set -e

    if [[ $status -eq 0 ]]; then
        rm -f "$log_file"
        return 0
    fi

    if grep -q 'default kernel not configured' "$log_file"; then
        rm -f "$log_file"
        log_warn "No default Apple Container kernel configured; installing the recommended kernel..."
        container system kernel set --recommended --force
        container build "$@"
        return $?
    fi

    rm -f "$log_file"
    return "$status"
}

container_name_from_dir() {
    local dir="$1"
    local base_name safe_name hash

    base_name=$(basename "$dir")
    safe_name=$(printf '%s' "$base_name" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-')
    safe_name=${safe_name#-}
    safe_name=${safe_name%-}
    [[ -n "$safe_name" ]] || safe_name="dir"
    hash=$(printf '%s' "$dir" | md5 | cut -c1-12)
    printf 'ai-sandbox-%s-%s-%s\n' "$SANDBOX_LAYOUT_VERSION" "$safe_name" "$hash"
}

container_exists() {
    local name="$1"
    container list -a 2>/dev/null | awk 'NR>1 {print $1}' | grep -qx "$name"
}

container_running() {
    local name="$1"
    container list 2>/dev/null | awk 'NR>1 {print $1}' | grep -qx "$name"
}

remove_container() {
    local name="$1"

    if container_exists "$name"; then
        log_info "Removing container: $name"
        container rm --force "$name"
    fi
}

ensure_host_mount_sources() {
    mkdir -p "$HOME/.config/opencode"
    mkdir -p "$HOME/.cache/opencode"
    mkdir -p "$HOME/.local/share/opencode"
    mkdir -p "$HOME/.local/state/opencode"
}

append_mount_if_exists() {
    local target_var_name="$1"
    local source="$2"
    local dest="$3"
    local readonly="${4:-}"

    [[ -e "$source" ]] || return 0

    local mount="type=bind,source=${source},target=${dest}"
    if [[ "$readonly" == "readonly" ]]; then
        mount+=",readonly"
    fi

    local quoted_mount
    quoted_mount=$(printf '%q' "$mount")
    eval "$target_var_name+=(\"--mount\" $quoted_mount)"
}

create_container() {
    local work_dir="$1"
    local container_name="$2"

    work_dir=$(cd "$work_dir" && pwd)

    local container_home host_uid host_gid memory cpus
    local git_name git_email

    container_home="$SANDBOX_HOME"
    host_uid=$(id -u)
    host_gid=$(id -g)
    memory="${AI_SANDBOX_MEMORY:-4G}"
    cpus="${AI_SANDBOX_CPUS:-}"
    git_name=$(git config --global user.name 2>/dev/null || true)
    git_email=$(git config --global user.email 2>/dev/null || true)

    ensure_host_mount_sources

    local idle_cmd
    idle_cmd=$(cat <<'EOF'
set -e
trap 'exit 0' INT TERM
while :; do
  sleep 3600 &
  wait $!
done
EOF
)

    local create_args=(
        "--name" "$container_name"
        "--interactive"
        "--tty"
        "--uid" "$host_uid"
        "--gid" "$host_gid"
        "--memory" "$memory"
        "-e" "HOME=${container_home}"
        "-e" "PATH=${SANDBOX_PATH}"
        "-e" "OPENCODE_CONFIG=${container_home}/.config/opencode/opencode-yolo.jsonc"
        "-e" "ZDOTDIR=/root"
        "-e" "COLORTERM=truecolor"
        "-e" "GIT_SSH_COMMAND=false"
    )

    if [[ -n "$git_name" ]]; then
        create_args+=("-e" "GIT_AUTHOR_NAME=${git_name}" "-e" "GIT_COMMITTER_NAME=${git_name}")
    fi
    if [[ -n "$git_email" ]]; then
        create_args+=("-e" "GIT_AUTHOR_EMAIL=${git_email}" "-e" "GIT_COMMITTER_EMAIL=${git_email}")
    fi
    if [[ -n "$cpus" ]]; then
        create_args+=("--cpus" "$cpus")
    fi

    append_mount_if_exists create_args "$work_dir" "$work_dir"
    append_mount_if_exists create_args "$HOME/.config/opencode" "$container_home/.config/opencode"
    append_mount_if_exists create_args "$HOME/.cache/opencode" "$container_home/.cache/opencode"
    append_mount_if_exists create_args "$HOME/.local/share/opencode" "$container_home/.local/share/opencode"
    append_mount_if_exists create_args "$HOME/.local/state/opencode" "$container_home/.local/state/opencode"
    append_mount_if_exists create_args "$HOME/.agents" "$container_home/.agents" readonly

    log_info "Creating sandbox: $container_name"
    container create "${create_args[@]}" "$SANDBOX_IMAGE" /bin/bash -lc "$idle_cmd"
}

ensure_container_running() {
    local work_dir="$1"
    local container_name="$2"

    if ! container_exists "$container_name"; then
        create_container "$work_dir" "$container_name"
    fi

    if ! container_running "$container_name"; then
        log_info "Starting sandbox: $container_name"
        container start "$container_name"
    fi

    ensure_opencode_installed "$container_name"
}

ensure_opencode_installed() {
    local container_name="$1"

    if container exec \
        --env "HOME=${SANDBOX_HOME}" \
        --env "PATH=${SANDBOX_PATH}" \
        "$container_name" \
        /bin/bash -lc 'command -v opencode >/dev/null 2>&1'; then
        return 0
    fi

    log_info "Installing OpenCode in sandbox..."
    container exec \
        --env "HOME=${SANDBOX_HOME}" \
        --env "PATH=${SANDBOX_PATH}" \
        "$container_name" \
        /bin/bash -lc 'curl -fsSL https://opencode.ai/install | bash -s -- --no-modify-path'
}

exec_in_sandbox() {
    local work_dir="$1"
    local container_name="$2"
    local mode="$3"
    shift 3
    local -a opencode_args=("$@")

    local prep_cmd
    prep_cmd=$(cat <<'EOF'
: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_STATE_HOME:=$HOME/.local/state}"
mkdir -p "$HOME" "$XDG_CONFIG_HOME/opencode" "$XDG_CACHE_HOME/opencode" \
  "$XDG_DATA_HOME/opencode" "$XDG_STATE_HOME/opencode"
if [ -f .tool-versions ] || [ -f .mise.toml ] || [ -f mise.toml ]; then
  /usr/local/bin/mise install --yes 2>&1 | tail -5 || true
  eval "$(/usr/local/bin/mise activate bash)" 2>/dev/null || true
fi
EOF
)

    local -a cmd
    case "$mode" in
        shell)
            cmd=(/bin/bash -lc "${prep_cmd}; exec /bin/zsh")
            ;;
        opencode)
            cmd=(/bin/bash -lc "${prep_cmd}; exec \"\$@\"" bash opencode --pure)
            if ((${#opencode_args[@]})); then
                cmd+=("${opencode_args[@]}")
            fi
            ;;
        *)
            log_error "Unsupported exec mode: $mode"
            exit 1
            ;;
    esac

    local -a exec_args=(
        --env "HOME=${SANDBOX_HOME}"
        --env "PATH=${SANDBOX_PATH}"
        --env "OPENCODE_CONFIG=${SANDBOX_HOME}/.config/opencode/opencode-yolo.jsonc"
        --env "GIT_SSH_COMMAND=false"
        --env "TERM=${TERM:-xterm-256color}"
        --workdir "$work_dir"
    )
    if [[ -t 0 ]]; then
        exec_args=(--interactive --tty "${exec_args[@]}")
    fi

    container exec "${exec_args[@]}" "$container_name" "${cmd[@]}"
}

prune_sandboxes() {
    local containers

    containers=$(container list -a 2>/dev/null | awk 'NR>1 && $1 ~ /^ai-sandbox-/ {print $1}')
    if [[ -n "$containers" ]]; then
        log_info "Removing sandbox containers..."
        while IFS= read -r ctr; do
            [[ -n "$ctr" ]] || continue
            remove_container "$ctr"
        done <<< "$containers"
    else
        log_info "No ai-sandbox containers found"
    fi

    log_success "Prune complete"
}

main() {
    local work_dir="."
    local command="opencode"
    local -a command_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            --)
                shift
                command_args=("$@")
                break
                ;;
            build|reset|prune|shell)
                command="$1"
                shift
                command_args=("$@")
                break
                ;;
            *)
                command_args=("$@")
                break
                ;;
        esac
    done

    work_dir=$(cd "$work_dir" && pwd)
    if [[ ! -d "$work_dir" ]]; then
        log_error "Directory does not exist: $work_dir"
        exit 1
    fi

    local container_name
    container_name=$(container_name_from_dir "$work_dir")

    ensure_system_running

    case "$command" in
        build)
            local no_cache=""
            if ((${#command_args[@]})); then
                for arg in "${command_args[@]}"; do
                    if [[ "$arg" == "--no-cache" ]]; then
                        no_cache=true
                    else
                        log_error "Unknown build option: $arg"
                        exit 1
                    fi
                done
            fi
            build_image true "$no_cache"
            ;;
        reset)
            build_image
            remove_container "$container_name"
            log_success "Sandbox reset"
            ;;
        prune)
            prune_sandboxes
            ;;
        shell|opencode)
            build_image
            ensure_container_running "$work_dir" "$container_name"
            exec_in_sandbox "$work_dir" "$container_name" "$command" "${command_args[@]}"
            ;;
        *)
            log_error "Unsupported command: $command"
            exit 1
            ;;
    esac
}

main "$@"
