#!/bin/bash
# Note: upgrade the Apple container CLI with /usr/local/bin/update-container.sh

set -euo pipefail

SANDBOX_IMAGE="ai-sandbox:latest"
DOCKERFILE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $*"; }
log_success() { echo -e "${GREEN}[OK]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }

sync_claude_credentials() {
    local claude_dir creds tmp_file

    claude_dir="$HOME/.claude"
    mkdir -p "$claude_dir"

    creds=$(security find-generic-password -s "Claude Code-credentials" -a "$(whoami)" -w 2>/dev/null || true)
    if [[ -z "$creds" ]]; then
        log_warn "No Claude credentials found in Keychain; using existing ~/.claude state"
        return 0
    fi

    tmp_file=$(mktemp "${claude_dir}/.credentials.json.tmp.XXXXXX")
    chmod 600 "$tmp_file"
    printf '%s' "$creds" > "$tmp_file"
    mv "$tmp_file" "${claude_dir}/.credentials.json"
}

usage() {
    cat <<EOF
Usage: ai-sandbox [build|reset|prune]

Run a persistent AI sandbox in Apple Containers.

COMMANDS:
    build       Build/rebuild the sandbox image
    reset       Remove the sandbox for the current directory
    prune       Delete all ai-sandbox containers and volumes

With no arguments, ai-sandbox starts or reuses the sandbox for the current
directory and opens an interactive shell inside it.

OPTIONS:
    -h, --help  Show this help message

EXAMPLES:
    ai-sandbox                  # Open a shell in the sandbox
    ai-sandbox build            # Build/rebuild the image
    ai-sandbox build --no-cache # Rebuild from scratch
    ai-sandbox reset            # Remove the current sandbox

NOTES:
    Upgrade the Apple container CLI with /usr/local/bin/update-container.sh

EOF
}

ensure_system_running() {
    if ! container ls &>/dev/null; then
        log_info "Starting container system..."
        container system start
        sleep 2
    fi
}

build_image() {
    local force="${1:-}"
    local no_cache="${2:-}"

    if [[ -z "$force" ]] && container image list 2>/dev/null | grep -q "$SANDBOX_IMAGE"; then
        return 0
    fi

    local host_home host_uid host_gid opencode_version
    host_home="$HOME"
    host_uid=$(id -u)
    host_gid=$(id -g)
    opencode_version=$(opencode --version 2>/dev/null || true)
    if [[ -z "$opencode_version" ]]; then
        log_error "Could not detect host opencode version"
        exit 1
    fi

    log_info "Building sandbox image..."

    local build_args=(
        -f "${DOCKERFILE_DIR}/Dockerfile.ai-sandbox"
        -t "$SANDBOX_IMAGE"
        --build-arg "HOST_HOME=${host_home}"
        --build-arg "HOST_UID=${host_uid}"
        --build-arg "HOST_GID=${host_gid}"
    )
    build_args+=(--build-arg "OPENCODE_VERSION=${opencode_version}")
    if [[ -n "$no_cache" ]]; then
        build_args+=(--no-cache)
    fi
    build_args+=("${DOCKERFILE_DIR}")

    container build "${build_args[@]}"
    log_success "Image built successfully"
}

container_name_from_dir() {
    local dir="$1"
    local base_name safe_name hash
    base_name=$(basename "$dir")
    safe_name=$(printf '%s' "$base_name" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-')
    safe_name=${safe_name#-}
    safe_name=${safe_name%-}
    [[ -n "$safe_name" ]] || safe_name="dir"
    hash=$(echo "$dir" | md5 | cut -c1-12)
    echo "ai-sandbox-${safe_name}-${hash}"
}

resolve_git_common_dir() {
    local work_dir="$1"
    local git_path="${work_dir}/.git"

    [[ -f "$git_path" ]] || return 0

    local gitdir
    gitdir=$(python3 - <<'PY' "$git_path"
import os
import sys

git_path = sys.argv[1]
with open(git_path, encoding="utf-8") as fh:
    for line in fh:
        if line.startswith("gitdir: "):
            gitdir = line[len("gitdir: "):].strip()
            if not os.path.isabs(gitdir):
                gitdir = os.path.normpath(os.path.join(os.path.dirname(git_path), gitdir))
            print(gitdir)
            break
PY
)

    [[ -n "$gitdir" ]] || return 0

    if [[ -f "${gitdir}/commondir" ]]; then
        python3 - <<'PY' "$gitdir"
import os
import sys

gitdir = sys.argv[1]
with open(os.path.join(gitdir, "commondir"), encoding="utf-8") as fh:
    commondir = fh.read().strip()
print(os.path.normpath(os.path.join(gitdir, commondir)))
PY
    else
        python3 - <<'PY' "$gitdir"
import os
import sys

gitdir = sys.argv[1]
print(os.path.normpath(os.path.join(gitdir, "..", "..")))
PY
    fi
}

container_exists() {
    local name="$1"
    container list -a 2>/dev/null | awk 'NR>1 {print $1}' | grep -qx "$name"
}

container_running() {
    local name="$1"
    container list 2>/dev/null | awk 'NR>1 {print $1}' | grep -qx "$name"
}

remove_container() {
    local name="$1"
    if container_exists "$name"; then
        log_info "Removing container: $name"
        container rm --force "$name"
    fi
}

ensure_host_mount_sources() {
    local work_dir="$1"
    local worktrees_dir="$2"

    mkdir -p "$HOME/.claude"
    mkdir -p "$HOME/.config/opencode"
    mkdir -p "$HOME/.local/bin"
    mkdir -p "$HOME/.local/share/opencode"
    mkdir -p "$HOME/.local/share/mise"
    mkdir -p "$HOME/.cache/opencode"
    mkdir -p "$HOME/.cache/mise"
    mkdir -p "$worktrees_dir"

    if [[ -d "$work_dir/.git" ]]; then
        mkdir -p "$work_dir/.git"
    fi

    if [[ -d "$HOME/src/dotfiles" ]]; then
        mkdir -p "$HOME/src/dotfiles/claude"
        mkdir -p "$HOME/src/dotfiles/opencode"
    fi
}

append_mount_if_exists() {
    local target_var_name="$1"
    local source="$2"
    local dest="$3"
    local readonly="${4:-}"

    [[ -e "$source" ]] || return 0

    local mount="type=bind,source=${source},target=${dest}"
    if [[ "$readonly" == "readonly" ]]; then
        mount+=",readonly"
    fi

    local quoted_mount
    quoted_mount=$(printf '%q' "$mount")
    eval "$target_var_name+=(\"--mount\" $quoted_mount)"
}

paths_equal() {
    local left="$1"
    local right="$2"
    [[ "$(cd "$left" && pwd)" == "$(cd "$right" && pwd)" ]]
}

create_container() {
    local work_dir="$1"
    local container_name="$2"

    work_dir=$(cd "$work_dir" && pwd)

    local container_home host_uid host_gid memory cpus
    local git_common_dir worktrees_dir
    local git_name git_email home_dotfiles

    container_home="$HOME"
    host_uid=$(id -u)
    host_gid=$(id -g)
    memory="${AI_SANDBOX_MEMORY:-8G}"
    cpus="${AI_SANDBOX_CPUS:-}"
    git_common_dir=$(resolve_git_common_dir "$work_dir")
    worktrees_dir="$(cd "$work_dir/.." && pwd)/worktrees"
    git_name=$(git config --global user.name 2>/dev/null || true)
    git_email=$(git config --global user.email 2>/dev/null || true)
    home_dotfiles="${HOME}/src/dotfiles"

    ensure_host_mount_sources "$work_dir" "$worktrees_dir"

    local idle_cmd
    idle_cmd=$(cat <<'EOF'
set -e
trap 'exit 0' INT TERM
while :; do
  sleep 3600 &
  wait $!
done
EOF
)

    local create_args=(
        "--name" "$container_name"
        "--interactive"
        "--tty"
        "--uid" "$host_uid"
        "--gid" "$host_gid"
        "--memory" "$memory"
        "--mount" "type=bind,source=${container_home},target=${container_home},readonly"
        "-e" "HOME=${container_home}"
        "-e" "PATH=${container_home}/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
        "-e" "ZDOTDIR=/root"
        "-e" "COLORTERM=truecolor"
        "-e" "GIT_SSH_COMMAND=ssh -o BatchMode=yes"
    )

    if [[ -n "$git_name" ]]; then
        create_args+=("-e" "GIT_AUTHOR_NAME=${git_name}" "-e" "GIT_COMMITTER_NAME=${git_name}")
    fi
    if [[ -n "$git_email" ]]; then
        create_args+=("-e" "GIT_AUTHOR_EMAIL=${git_email}" "-e" "GIT_COMMITTER_EMAIL=${git_email}")
    fi
    if [[ -n "$cpus" ]]; then
        create_args+=("--cpus" "$cpus")
    fi

    append_mount_if_exists create_args "$work_dir" "$work_dir"
    append_mount_if_exists create_args "$worktrees_dir" "$worktrees_dir"
    append_mount_if_exists create_args "$HOME/.claude" "$HOME/.claude"
    append_mount_if_exists create_args "$HOME/.config/opencode" "$HOME/.config/opencode"
    append_mount_if_exists create_args "$HOME/.local/bin" "$HOME/.local/bin"
    append_mount_if_exists create_args "$HOME/.local/share/opencode" "$HOME/.local/share/opencode"
    append_mount_if_exists create_args "$HOME/.local/share/mise" "$HOME/.local/share/mise"
    append_mount_if_exists create_args "$HOME/.cache/opencode" "$HOME/.cache/opencode"
    append_mount_if_exists create_args "$HOME/.cache/mise" "$HOME/.cache/mise"

    if [[ -n "$git_common_dir" ]]; then
        append_mount_if_exists create_args "$git_common_dir" "$git_common_dir"
    fi

    if [[ -d "$home_dotfiles" ]]; then
        if ! paths_equal "$home_dotfiles" "$work_dir"; then
            append_mount_if_exists create_args "$home_dotfiles" "$home_dotfiles" readonly
        fi
        append_mount_if_exists create_args "$home_dotfiles/claude" "$home_dotfiles/claude"
        append_mount_if_exists create_args "$home_dotfiles/opencode" "$home_dotfiles/opencode"
    fi

    log_info "Creating sandbox: $container_name"
    container create "${create_args[@]}" "$SANDBOX_IMAGE" /bin/bash -lc "$idle_cmd"
}

ensure_container_running() {
    local work_dir="$1"
    local container_name="$2"

    if ! container_exists "$container_name"; then
        create_container "$work_dir" "$container_name"
    fi

    if ! container_running "$container_name"; then
        log_info "Starting sandbox: $container_name"
        container start "$container_name"
    fi
}

exec_shell() {
    local work_dir="$1"
    local container_name="$2"

    local prep_cmd
    prep_cmd=$(cat <<'EOF'
: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_STATE_HOME:=$HOME/.local/state}"
mkdir -p "$HOME" "$XDG_CONFIG_HOME" "$XDG_CACHE_HOME" "$XDG_DATA_HOME" \
  "$XDG_STATE_HOME" "$HOME/.local/bin"
if [ -f .tool-versions ] || [ -f .mise.toml ] || [ -f mise.toml ]; then
  /usr/local/bin/mise install --yes 2>&1 | tail -5
  eval "$(/usr/local/bin/mise activate bash)"
fi
exec /bin/zsh
EOF
)

    container exec \
        --interactive \
        --tty \
        --workdir "$work_dir" \
        "$container_name" \
        /bin/bash --noprofile --norc -lc "$prep_cmd"
}

reset_sandbox() {
    local _work_dir="$1"
    local container_name="$2"

    remove_container "$container_name"
    log_success "Sandbox reset"
}

prune_sandboxes() {
    local containers volumes

    containers=$(container list -a 2>/dev/null | awk 'NR>1 && $1 ~ /^ai-sandbox-/ {print $1}')
    if [[ -n "$containers" ]]; then
        log_info "Removing sandbox containers..."
        while IFS= read -r ctr; do
            [[ -n "$ctr" ]] || continue
            remove_container "$ctr"
        done <<< "$containers"
    fi

    volumes=$(container volume list 2>/dev/null | awk '/^ai-sandbox-/ {print $1}')
    if [[ -z "$volumes" ]]; then
        log_info "No ai-sandbox volumes found"
        return 0
    fi

    log_info "Deleting ai-sandbox volumes..."
    while IFS= read -r vol; do
        [[ -n "$vol" ]] || continue
        container volume delete "$vol" && log_success "Deleted: $vol"
    done <<< "$volumes"

    log_success "Prune complete"
}

main() {
    local work_dir="."
    local command="shell"
    local -a command_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            build|reset|prune)
                command="$1"
                shift
                command_args=("$@")
                break
                ;;
            *)
                log_error "Unknown argument: $1"
                usage
                exit 1
                ;;
        esac
    done

    work_dir=$(cd "$work_dir" && pwd)
    if [[ ! -d "$work_dir" ]]; then
        log_error "Directory does not exist: $work_dir"
        exit 1
    fi

    local container_name
    container_name=$(container_name_from_dir "$work_dir")

    ensure_system_running

    case "$command" in
        build)
            local no_cache=""
            if ((${#command_args[@]})); then
                for arg in "${command_args[@]}"; do
                    if [[ "$arg" == "--no-cache" ]]; then
                        no_cache=true
                    else
                        log_error "Unknown build option: $arg"
                        exit 1
                    fi
                done
            fi
            build_image true "$no_cache"
            ;;
        reset)
            build_image
            reset_sandbox "$work_dir" "$container_name"
            ;;
        prune)
            prune_sandboxes
            ;;
        shell)
            build_image
            sync_claude_credentials
            ensure_container_running "$work_dir" "$container_name"
            exec_shell "$work_dir" "$container_name"
            ;;
        *)
            log_error "Unsupported command: $command"
            exit 1
            ;;
    esac
}

main "$@"
