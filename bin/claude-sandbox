#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/_ai-sandbox-common.sh"

_ai_sandbox_main \
    claude \
    --harness-dir "$HOME/.claude" \
    --harness-file "$HOME/.claude.json" \
    --exec-dir "$HOME/.local/share/claude" \
    --gocache-dir "$HOME/.claude/go-build-cache" \
    -- "$@"
