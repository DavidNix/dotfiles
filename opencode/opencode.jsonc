{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "default_agent": "plan",
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
    },
  },
  "share": "disabled",
  "autoupdate": "notify",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false,
    },
  },
  "model": "openai/gpt-5.5",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.envrc.*": "deny",
      "*.envrc.example": "allow",
      "*.vault-password": "deny",
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "codesearch": "allow",
    "bash": {
      "*": "ask",
      "bash -n *": "allow",
      "container *": "allow",
      "cp *": "allow",
      "file *": "allow",
      "find *": "allow",
      "git *": "allow", // plugin hook prevents dangerous commands
      "glab *": "allow",
      "go *": "allow", // plugin hook prevents dangerous commands
      "gofmt *": "allow",
      "goimports *": "allow",
      "golangci-lint *": "allow",
      "gopls *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "make dev *": "allow",
      "make fmt *": "allow",
      "make lint *": "allow",
      "make test *": "allow",
      "make vet *": "allow",
      "mkdir *": "allow",
      "mv *": "allow",
      "npm astro *": "allow",
      "npm audit *": "allow",
      "npm ci *": "allow",
      "npm view *": "allow",
      "npx astro *": "allow",
      "npx test *": "allow",
      "pwd *": "allow",
      "rg *": "allow",
      "ripgrep *": "allow",
      "shellcheck *": "allow",
      "stat *": "allow",
      "tail *": "allow",
      "terraform fmt *": "allow",
      "terraform init *": "allow",
      "terraform plan *": "allow",
      "terraform state list *": "allow",
      "terraform validate *": "allow",
      "uv run ansible-lint *": "allow",
      "wc *": "allow",
    },
    "skill": {
      "*": "allow",
      // "ai-tdd": "allow",
      // "brainstorm": "allow",
      // "docx": "allow",
      // "frontend-design": "allow",
      // "frontend-slides": "allow",
      // "opencode-config": "allow",
      // "opencode-plugin": "allow",
      // "pdf": "allow",
      // "prd": "allow",
      // "review-atodo": "allow",
      // "skill-creator": "allow",
      // "web-design-guidelines": "allow",
      // "writing-clearly-and-concisely": "allow",
      // "xlsx": "allow",
    },
    "task": {
      "*": "allow",
    },
    "external_directory": {
      "*": "ask",
      "/Users/*/go/pkg/mod/**": "allow",
    },
    "websearch": "ask",
    "question": "allow",
    "doom_loop": "ask",
    "context7*": "allow",
    "webfetch": "ask",
  },
}
