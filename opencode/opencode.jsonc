{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "default_agent": "plan",
  "disabled_providers": ["opencode", "baseten"],
  "model": "openai/gpt-5.6-sol-fast",
  "small_model": "homelab/qwen3.6-35b-a3b-nvfp4",
  "provider": {
    "homelab": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Homelab",
      "options": {
        "baseURL": "http://ai1-inference:8000/v1",
        "apiKey": "local",
      },
      "models": {
        "qwen3.6-35b-a3b-nvfp4": {
          "name": "Qwen3.6-35B-A3B",
        },
      },
    },
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.6-sol-fast",
    },
    "implementer": {
      "description": "Implements requested changes after the parent agent has planned the work.",
      "mode": "subagent",
      "hidden": true,
      "model": "xai/grok-4.5",
      "prompt": "You are an implementation-only subagent. Make the requested code or configuration changes directly. Do not delegate work. Use ai-tdd skill if present. Run ONLY FOCUSED tests, linters, formatters, type checks, diagnostics, or other verification. Return a concise summary of the changes and leave in-depth verification to the calling agent.",
      "permission": {
        "bash": "deny",
        "task": "deny",
      },
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "permission": { "task": "deny" }, // deny subagents from spawning more subagents
    },
    "general": {
      "model": "opencode-go/deepseek-v4-flash",
      "permission": { "task": "deny" }, // deny subagents from spawning more subagents
    },
    "summary": {
      "model": "opencode-go/deepseek-v4-flash",
    },
  },
  "share": "disabled",
  "autoupdate": "notify",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false,
    },
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.envrc": "deny",
      "*.envrc.*": "deny",
      "*.envrc.example": "allow",
      "*.vault-password": "deny",
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "codesearch": "allow",
    "bash": {
      // Default policy
      "*": "ask",

      // Shell validation
      "bash -n *": "allow",
      "shellcheck *": "allow",

      // Filesystem operations
      "cp *": "allow",
      "mkdir *": "allow",
      "mv *": "allow",

      // File inspection and navigation
      "basename *": "allow",
      "bat *": "allow",
      "cat *": "allow",
      "df *": "allow",
      "dirname *": "allow",
      "du *": "allow",
      "dust *": "allow",
      "file *": "allow",
      "find *": "allow",
      // find -delete remains blocked by the safe-commands plugin.
      "find *-exec*": "ask",
      "find *-ok*": "ask",
      "ls *": "allow",
      "lsd *": "allow",
      "pwd *": "allow",
      "readlink *": "allow",
      "realpath *": "allow",
      "stat *": "allow",
      "tree *": "allow",

      // Search and text processing
      "cmp *": "allow",
      "column *": "allow",
      "comm *": "allow",
      "cut *": "allow",
      "diff *": "allow",
      "fold *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "join *": "allow",
      "jq *": "allow",
      "nl *": "allow",
      "paste *": "allow",
      "rg *": "allow",
      "ripgrep *": "allow",
      "sort *": "allow",
      "strings *": "allow",
      "tac *": "allow",
      "tail *": "allow",
      "tr *": "allow",
      "uniq *": "allow",
      "wc *": "allow",

      // Checksums and archive inspection
      "md5 *": "allow",
      "shasum *": "allow",
      "unzip -l *": "allow",
      "zipinfo *": "allow",

      // System and process inspection
      "command -v *": "allow",
      "id *": "allow",
      "iostat *": "allow",
      "lsof *": "allow",
      "pgrep *": "allow",
      "procs *": "allow",
      "ps *": "allow",
      "sw_vers *": "allow",
      "uname *": "allow",
      "uptime *": "allow",
      "vm_stat *": "allow",
      "whereis *": "allow",
      "which *": "allow",
      "whoami *": "allow",

      // Documentation and code statistics
      "apropos *": "allow",
      "man *": "allow",
      "tokei *": "allow",
      "whatis *": "allow",

      // Diagram rendering
      "merman-cli *": "allow",

      // Version control and hosting
      "git *": "allow", // plugin hook prevents dangerous commands
      "glab *": "allow",

      // Go tooling
      "go *": "allow", // plugin hook prevents dangerous commands
      "gofmt *": "allow",
      "goimports *": "allow",
      "golangci-lint *": "allow",
      "gopls *": "allow",

      // Node.js tooling
      "npm astro *": "allow",
      "npm audit *": "allow",
      "npm ci *": "allow",
      "npm explain *": "allow",
      "npm list *": "allow",
      "npm view *": "allow",
      "npx astro *": "allow",
      "npx test *": "allow",

      // Homebrew inspection
      "brew deps *": "allow",
      "brew info *": "allow",
      "brew leaves *": "allow",
      "brew list *": "allow",
      "brew search *": "allow",
      "brew uses *": "allow",

      // uv and mise inspection
      "mise current *": "allow",
      "mise doctor *": "allow",
      "mise ls *": "allow",
      "mise where *": "allow",
      "mise which *": "allow",
      "uv pip check *": "allow",
      "uv pip freeze *": "allow",
      "uv pip list *": "allow",
      "uv pip show *": "allow",
      "uv python find *": "allow",
      "uv python list *": "allow",
      "uv tool list *": "allow",
      "uv tree *": "allow",

      // Trusted Make targets
      "make dev *": "allow",
      "make fmt *": "allow",
      "make lint *": "allow",
      "make test *": "allow",
      "make vet *": "allow",

      // Infrastructure validation
      "terraform fmt *": "allow",
      "terraform init *": "allow",
      "terraform plan *": "allow",
      "terraform state list *": "allow",
      "terraform validate *": "allow",
      "uv run ansible-lint *": "allow",

      // Container tooling
      "container *": "allow",
    },
    "skill": {
      "*": "allow",
      // "ai-tdd": "allow",
      // "brainstorm": "allow",
      // "docx": "allow",
      // "frontend-design": "allow",
      // "frontend-slides": "allow",
      // "opencode-config": "allow",
      // "opencode-plugin": "allow",
      // "pdf": "allow",
      // "prd": "allow",
      // "review-atodo": "allow",
      // "skill-creator": "allow",
      // "web-design-guidelines": "allow",
      // "writing-clearly-and-concisely": "allow",
      // "xlsx": "allow",
    },
    "task": {
      "*": "allow",
    },
    "external_directory": {
      "*": "ask",
      "/Users/*/go/pkg/mod/**": "allow",
    },
    "websearch": "ask",
    "question": "allow",
    "doom_loop": "ask",
    "context7*": "allow",
    "webfetch": "allow",
  },
}
